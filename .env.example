# PostgreSQL connection string (server-only). Never use NEXT_PUBLIC_ for this.
# Required for production runtime and for local scripts that use PostgreSQL
# (db:seed:demo, smoke:persistence, npm start).
DATABASE_URL=postgres://user:pass@localhost:5432/oscal_control_tool

# Legacy SQLite path (server-only). Used only when migrating or cutting over
# from the SQLite persistence layer; not used by the PostgreSQL application path.
# Default when unset (development/test only): ./data/oscal-control-tool.sqlite
# DATABASE_PATH=./data/oscal-control-tool.sqlite

# --- Authentication (Better Auth, ADR-015) ---
# Server-only signing secret for opaque sessions. REQUIRED in production
# (startup fails closed if unset). Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Public base URL of the app, used for auth callbacks, cookies, and invitation
# links. Only the non-secret public URL may use NEXT_PUBLIC_.
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Development-only email sink. Verification and invitation URLs are written here
# (JSON lines) so flows can be completed without a real email provider. Never
# used in production (tokens/links are never logged in production). Defaults to
# data/email-sink.json when unset.
# TEST_EMAIL_SINK=./data/email-sink.json

# --- Bootstrap first admin (scripts/bootstrap-admin.ts, ADR-019) ---
# One-time creation of the initial organization + organization_admin. Never
# commit real values; never seed shared public credentials.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-at-least-12-chars
# BOOTSTRAP_ADMIN_NAME=Platform Admin
# BOOTSTRAP_ORG_NAME=Demo Organization
# BOOTSTRAP_ORG_SLUG=demo-organization

# Organization slug that owns the seeded demo project (db:seed:demo).
# SEED_DEMO_ORG_SLUG=demo-organization

# --- Production / Render ---
# On Render, set DATABASE_URL to the managed PostgreSQL connection string.
#
# When true, production startup runs the idempotent CGDS demo seed (no --reset).
# Absent or false: skip seeding.
# SEED_DEMO_PROJECT=true
#
# Listen port (Render injects PORT automatically):
# PORT=3000
