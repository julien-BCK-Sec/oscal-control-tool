# Local SQLite path (server-only). Never use NEXT_PUBLIC_ for this.
# Default when unset (development/test only): ./data/oscal-control-tool.sqlite
DATABASE_PATH=./data/oscal-control-tool.sqlite

# --- Production / Render ---
# On Render, set an absolute path on the persistent disk (required):
# DATABASE_PATH=/var/data/oscal-author.db
#
# When true, production startup runs the idempotent CGDS demo seed (no --reset).
# Absent or false: skip seeding.
# SEED_DEMO_PROJECT=true
#
# Listen port (Render injects PORT automatically):
# PORT=3000
