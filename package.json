{
  "name": "oscal-control-tool",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "derive:framework": "tsx scripts/derive-nist-moderate-framework.ts",
    "prebuild": "npm run derive:framework",
    "pretest": "npm run derive:framework",
    "build": "next build",
    "start": "tsx --require ./scripts/mock-server-only.cjs scripts/start-production.ts",
    "start:next": "next start -H 0.0.0.0",
    "lint": "eslint",
    "test": "tsx --require ./scripts/mock-server-only.cjs --test \"src/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate --config=drizzle-pg.config.ts",
    "db:generate:sqlite": "drizzle-kit generate",
    "db:migrate": "tsx --require ./scripts/mock-server-only.cjs scripts/db-migrate.ts",
    "db:migrate:sqlite-to-pg": "tsx --require ./scripts/mock-server-only.cjs scripts/migrate-sqlite-to-postgres.ts",
    "db:seed:demo": "tsx --require ./scripts/mock-server-only.cjs scripts/seed-demo.ts",
    "db:studio": "drizzle-kit studio --config=drizzle-pg.config.ts",
    "smoke:persistence": "tsx --require ./scripts/mock-server-only.cjs scripts/smoke-persistence.ts",
    "predev": "npm run db:migrate"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^13.0.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.11",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "allowScripts": {
    "better-sqlite3@13.0.1": true
  }
}
